<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>YomiType 読みタイプ｜不再死背五十音，用打字練出日語腦</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700;900&family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --navy:#1A2744; --navy-mid:#2C3D6B;
  --paper:#F5F2E8; --paper-dark:#EDE9D8; --cream:#FBF8EF;
  --gold:#C8960A; --gold-lt:#F0C040;
  --red:#C53030; --pink:#E0507A;
  --text-dark:#1A2744; --text-mid:#3D4F7C; --text-soft:#7A8BAA;
  --white:#fff; --border:rgba(26,39,68,0.12);
  --bg-paper: url("data:image/png;base64,");
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'Noto Sans TC',sans-serif;background:var(--paper);color:var(--text-dark);overflow-x:hidden;}

/* TICKER */
.ticker{background:var(--navy);color:rgba(255,255,255,.5);font-size:11px;padding:6px 0;overflow:hidden;white-space:nowrap;}
.ticker-inner{display:inline-block;animation:tick 30s linear infinite;}
.ticker-inner span{margin:0 28px;}
.ticker-inner .hi{color:var(--gold-lt);}
@keyframes tick{from{transform:translateX(100vw);}to{transform:translateX(-100%);}}

/* NAVBAR */
.navbar{position:sticky;top:0;z-index:100;background:var(--navy);display:flex;align-items:center;justify-content:space-between;padding:0 28px;height:52px;border-bottom:1px solid rgba(255,255,255,.07);}
.nav-logo svg{height:28px;width:auto;}
.nav-links{display:flex;align-items:center;gap:2px;}
.nav-links a{color:rgba(255,255,255,.7);font-size:13px;text-decoration:none;padding:6px 12px;border-radius:6px;transition:.2s;}
.nav-links a:hover{color:#fff;background:rgba(255,255,255,.1);}
.nav-btn{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#fff;font-size:13px;font-weight:700;padding:6px 18px;border-radius:20px;cursor:pointer;font-family:inherit;transition:.2s;}
.nav-btn:hover{background:rgba(255,255,255,.2);}

/* HERO */
.hero{
  background:var(--navy);
  min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;
  position:relative;overflow:hidden;padding:70px 24px 56px;
}
.hero-bg-paper{
  position:absolute;inset:0;
  background-image:var(--bg-paper);background-size:200px;
  opacity:.04;pointer-events:none;
}
/* floating TYPE! */
.tf{position:absolute;font-family:'Noto Serif JP',serif;font-weight:900;color:rgba(255,255,255,.055);user-select:none;pointer-events:none;animation:floaty 7s ease-in-out infinite;}
@keyframes floaty{0%,100%{transform:translateY(0);}50%{transform:translateY(-16px);}}

.hero-wrap{position:relative;z-index:2;max-width:840px;width:100%;}

/* HERO CARD */
.hero-card{
  background:var(--paper);
  background-image:var(--bg-paper);background-size:160px;
  border-radius:18px;padding:0;
  box-shadow:0 28px 80px rgba(0,0,0,.38);
  overflow:hidden;position:relative;
  display:grid;grid-template-columns:1fr 340px;
}
.hero-card-left{padding:44px 36px 36px;}
.hero-card-right{
  position:relative;overflow:hidden;
  background:linear-gradient(135deg,rgba(26,39,68,.06) 0%,rgba(200,150,10,.08) 100%);
  display:flex;align-items:flex-end;justify-content:center;
  min-height:440px;
}
.hero-illus{
  position:absolute;bottom:0;right:-10px;
  width:110%;max-width:400px;
  filter:drop-shadow(-8px 8px 24px rgba(0,0,0,.18));
}

/* corner dots */
.cdot{position:absolute;width:10px;height:10px;border-radius:50%;background:var(--navy);}
.cdot.tl{top:13px;left:13px;} .cdot.tr{top:13px;right:13px;}
.cdot.bl{bottom:13px;left:13px;} .cdot.br{bottom:13px;right:13px;}

.hero-logo-wrap{margin-bottom:20px;}
.hero-logo-wrap svg{height:56px;width:auto;max-width:100%;}
.hero-tagline-jp{font-family:'Noto Serif JP',serif;font-size:11px;color:var(--text-soft);letter-spacing:3px;margin-top:4px;}

.hero-content-badge{
  display:inline-flex;align-items:center;gap:7px;
  background:var(--navy);color:#fff;font-size:11px;font-weight:700;
  padding:3px 14px;border-radius:16px;margin-bottom:16px;
}
.hero-content-badge span{color:var(--gold-lt);}

.hero-h1{font-family:'Noto Sans TC',sans-serif;font-size:clamp(17px,2.6vw,24px);font-weight:900;color:var(--navy);line-height:1.45;margin-bottom:6px;}
.hero-h1 em{color:var(--red);font-style:normal;}
.hero-sub{font-size:13px;color:var(--text-soft);line-height:1.8;margin-bottom:20px;}

.hero-bullets{margin-bottom:24px;}
.hb{display:flex;align-items:flex-start;gap:9px;font-size:12.5px;color:var(--text-mid);padding:6px 0;border-bottom:1px solid var(--border);}
.hb:last-child{border:none;}
.hb-dot{width:6px;height:6px;border-radius:50%;background:var(--red);flex-shrink:0;margin-top:5px;}

.hero-cta{margin-bottom:14px;}
.free-trial{font-size:12px;color:var(--text-soft);font-style:italic;margin-bottom:10px;}
.cta-row{display:flex;gap:10px;flex-wrap:wrap;}
.btn-start{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--navy);color:#fff;font-family:inherit;font-size:14px;font-weight:900;
  padding:12px 28px;border-radius:26px;border:none;cursor:pointer;text-decoration:none;
  box-shadow:0 5px 20px rgba(26,39,68,.35);transition:.15s;
}
.btn-start:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(26,39,68,.45);}
.btn-start .sword-icon{width:18px;height:18px;flex-shrink:0;}
.btn-login{
  display:inline-block;background:transparent;color:var(--navy);
  font-family:inherit;font-size:13px;font-weight:700;
  padding:11px 22px;border-radius:26px;border:2px solid var(--navy);cursor:pointer;text-decoration:none;transition:.15s;
}
.btn-login:hover{background:var(--navy);color:#fff;}

.hero-bottom{font-family:'Noto Serif JP',serif;font-size:11px;color:var(--text-soft);letter-spacing:2px;}

/* ANNOUNCE STRIP */
.announce{
  background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.12);
  margin:14px 28px 0;border-radius:9px;padding:9px 18px;
  display:flex;align-items:center;gap:10px;font-size:12px;color:rgba(255,255,255,.6);
  position:absolute;top:52px;left:0;right:0;z-index:50;
}
.announce-lbl{background:rgba(255,255,255,.2);color:#fff;font-size:10px;font-weight:700;padding:2px 10px;border-radius:8px;white-space:nowrap;}

/* SECTION BASE */
.section{padding:72px 24px;}
.sl{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:10px;}
.sh2{font-family:'Noto Serif JP',serif;font-size:clamp(20px,3vw,30px);font-weight:900;color:var(--navy);margin-bottom:8px;line-height:1.4;}
.ssub{font-size:13px;color:var(--text-soft);margin-bottom:40px;}

/* ABOUT */
.section-about{background:var(--cream);background-image:var(--bg-paper);background-size:200px;}
.about-grid{max-width:960px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;}
.about-text p{font-size:13.5px;color:var(--text-mid);line-height:1.9;margin-bottom:10px;}
.about-pain{color:var(--red);font-weight:700;font-size:13px;line-height:2.1;}
.about-em{font-weight:900;color:var(--navy);font-size:15px;margin-top:6px;}
.about-right{text-align:center;}
.about-illus{width:100%;max-width:320px;filter:drop-shadow(0 12px 32px rgba(0,0,0,.12));}
.feature-pills{margin-top:24px;display:flex;flex-direction:column;gap:11px;}
.pill{background:#fff;border:1px solid var(--border);border-radius:12px;padding:13px 16px;display:flex;gap:11px;align-items:flex-start;}
.pill-icon{font-size:18px;flex-shrink:0;}
.pt{font-size:13px;font-weight:700;color:var(--navy);margin-bottom:2px;}
.pd{font-size:11.5px;color:var(--text-soft);line-height:1.6;}

/* DEMO */
.section-demo{background:var(--navy);text-align:center;}
.section-demo .sl{color:var(--gold-lt);}
.section-demo .sh2{color:#fff;}
.section-demo .ssub{color:rgba(255,255,255,.45);}
.demo-card{background:var(--paper);background-image:var(--bg-paper);background-size:160px;border-radius:16px;max-width:660px;margin:0 auto;padding:32px 28px;box-shadow:0 20px 60px rgba(0,0,0,.4);}
.demo-jp{font-family:'Noto Serif JP',serif;font-size:clamp(28px,5vw,46px);font-weight:700;letter-spacing:3px;display:flex;flex-wrap:wrap;justify-content:center;gap:3px;margin-bottom:10px;}
.dc{color:#C8C8C8;transition:color .3s;}
.dc.done{color:var(--navy);font-weight:900;}
.dc.cur{color:var(--navy-mid);border-bottom:3px solid var(--red);padding-bottom:1px;}
.demo-zh{font-size:13px;color:var(--text-soft);min-height:20px;margin-bottom:20px;transition:opacity .4s;}
.demo-input{width:240px;padding:11px 20px;font-size:17px;font-family:inherit;border:2px solid rgba(26,39,68,.18);border-radius:26px;outline:none;text-align:center;transition:.2s;background:#fff;}
.demo-input:focus{border-color:var(--navy-mid);box-shadow:0 2px 14px rgba(26,39,68,.1);}
.demo-input.wrong{animation:shake .3s;border-color:var(--red);background:#fff8f8;}
.demo-input.right{border-color:#38A169;}
.demo-hint{font-size:11px;color:var(--text-soft);margin-top:12px;}
@keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-5px);}75%{transform:translateX(5px);}}

/* LEVELS */
.section-levels{background:var(--paper);background-image:var(--bg-paper);background-size:200px;text-align:center;}
.levels-grid{max-width:920px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
.level-card{background:#fff;border-radius:16px;padding:24px 20px 28px;border:1px solid var(--border);transition:.2s;position:relative;overflow:hidden;}
.level-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(26,39,68,.1);}
.level-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:var(--navy);}
.level-illus{width:80px;height:80px;margin:0 auto 14px;}
.level-illus svg{width:100%;height:100%;}
.lbadge{display:inline-flex;align-items:center;gap:5px;background:var(--navy);color:#fff;font-size:10px;font-weight:700;padding:2px 11px;border-radius:9px;margin-bottom:10px;}
.lbadge span{color:var(--gold-lt);}
.lt{font-family:'Noto Serif JP',serif;font-size:17px;font-weight:900;color:var(--navy);margin-bottom:4px;}
.ls{font-size:11px;color:var(--gold);font-weight:700;margin-bottom:10px;}
.ld{font-size:12px;color:var(--text-mid);line-height:1.8;text-align:left;}

/* FEATURES */
.section-features{background:var(--paper-dark);background-image:var(--bg-paper);background-size:200px;text-align:center;}
.features-grid{max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(2,1fr);gap:18px;}
.fi{background:#fff;border-radius:13px;padding:22px;display:flex;gap:13px;border:1px solid var(--border);transition:.2s;text-align:left;}
.fi:hover{box-shadow:0 6px 22px rgba(26,39,68,.08);}
.fi-icon{font-size:26px;flex-shrink:0;}
.fi-t{font-size:13.5px;font-weight:700;color:var(--navy);margin-bottom:4px;}
.fi-d{font-size:12px;color:var(--text-soft);line-height:1.7;}

/* TYPEBOOK SECTION */
.section-typebook{background:var(--navy);padding:72px 24px;display:flex;align-items:center;justify-content:center;gap:48px;flex-wrap:wrap;}
.typebook-text{max-width:420px;color:#fff;}
.typebook-text .sl{color:var(--gold-lt);}
.typebook-text .sh2{color:#fff;}
.typebook-text p{font-size:13.5px;color:rgba(255,255,255,.55);line-height:1.9;margin-bottom:14px;}
.typebook-img{width:260px;flex-shrink:0;filter:drop-shadow(0 16px 40px rgba(0,0,0,.4));animation:floaty 5s ease-in-out infinite;}

/* NEWS */
.section-news{background:var(--navy);padding:72px 24px;text-align:center;}
.section-news .sh2{color:#fff;}
.section-news .ssub{color:rgba(255,255,255,.45);}
.news-strip{display:flex;gap:13px;max-width:860px;margin:0 auto;overflow-x:auto;padding-bottom:8px;}
.nc{flex:0 0 250px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:16px;text-align:left;transition:.2s;cursor:pointer;}
.nc:hover{background:rgba(255,255,255,.12);}
.nc-tag{font-size:10px;font-weight:700;color:var(--gold-lt);letter-spacing:1px;margin-bottom:7px;}
.nc-title{font-size:12.5px;font-weight:700;color:#fff;margin-bottom:5px;line-height:1.5;}
.nc-prev{font-size:11px;color:rgba(255,255,255,.35);line-height:1.6;}
.nc-lock{font-size:10px;color:rgba(255,255,255,.3);margin-top:9px;}

/* PRICING */
.section-pricing{background:var(--cream);background-image:var(--bg-paper);background-size:200px;text-align:center;}
.pricing-wrap{max-width:780px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:22px;align-items:start;}
.pc{background:#fff;border-radius:18px;border:2px solid var(--border);padding:32px 26px;position:relative;text-align:left;}
.pc.premium{border-color:var(--navy);box-shadow:0 12px 48px rgba(26,39,68,.14);}
.pc.premium::before{content:'狂熱方案';position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:var(--navy);color:#fff;font-size:10px;font-weight:700;padding:3px 16px;border-radius:16px;white-space:nowrap;}
.pc-book{position:absolute;top:-32px;right:16px;width:64px;opacity:.85;}
.plan-name{font-size:13px;font-weight:700;color:var(--text-soft);margin-bottom:7px;}
.plan-price{font-family:'Noto Serif JP',serif;font-size:36px;font-weight:900;color:var(--navy);}
.plan-price sup{font-size:14px;vertical-align:super;}
.plan-price sub{font-size:13px;color:var(--text-soft);}
.plan-disc{font-size:11.5px;color:var(--text-soft);margin-bottom:4px;}
.plan-disc .orig{text-decoration:line-through;margin-right:5px;}
.plan-disc .save{color:var(--red);font-weight:700;}
.plan-q{font-size:11px;color:var(--gold);font-weight:700;margin-bottom:18px;}
.pdiv{border:none;border-top:1px solid var(--border);margin:14px 0;}
.pf{display:flex;align-items:flex-start;gap:9px;font-size:12.5px;color:var(--text-dark);padding:6px 0;border-bottom:1px solid var(--border);line-height:1.4;}
.pf:last-child{border:none;}
.pf .ck{flex-shrink:0;font-size:14px;width:16px;height:16px;}
.pf .no{opacity:.25;}
.plan-btn{margin-top:22px;display:block;width:100%;background:var(--navy);color:#fff;font-family:inherit;font-size:14px;font-weight:900;padding:13px;border-radius:11px;border:none;cursor:pointer;text-align:center;text-decoration:none;transition:.15s;}
.plan-btn:hover{opacity:.85;}
.plan-btn.out{background:transparent;color:var(--navy);border:2px solid var(--navy);}
.plan-btn.out:hover{background:var(--navy);color:#fff;}

/* CTA BOTTOM */
.section-cta{background:var(--navy);padding:80px 24px;text-align:center;}
.cta-logo{margin-bottom:24px;}
.cta-logo svg{height:52px;width:auto;max-width:320px;}
.cta-jp{font-family:'Noto Serif JP',serif;font-size:12px;color:rgba(255,255,255,.35);letter-spacing:3px;margin-top:6px;}
.section-cta h2{font-family:'Noto Serif JP',serif;font-size:clamp(20px,3.5vw,34px);font-weight:900;color:#fff;margin-bottom:14px;line-height:1.4;}
.section-cta p{font-size:13px;color:rgba(255,255,255,.45);max-width:440px;margin:0 auto 28px;line-height:1.8;}
.cta-knight{width:120px;margin:0 auto 20px;filter:drop-shadow(0 8px 20px rgba(0,0,0,.4));animation:floaty 5s ease-in-out infinite;}
.btn-start-lg{
  display:inline-flex;align-items:center;gap:10px;
  background:var(--paper);color:var(--navy);font-family:inherit;font-size:15px;font-weight:900;
  padding:15px 48px;border-radius:30px;border:none;cursor:pointer;text-decoration:none;
  box-shadow:0 6px 30px rgba(0,0,0,.3);transition:.15s;
}
.btn-start-lg:hover{transform:scale(1.04);}

/* FOOTER */
footer{background:#0F1828;padding:28px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;}
.footer-logo svg{height:22px;width:auto;}
.footer-jp{font-family:'Noto Serif JP',serif;font-size:10px;color:rgba(255,255,255,.25);letter-spacing:2px;margin-top:4px;}
.footer-info{font-size:11px;color:rgba(255,255,255,.3);text-align:right;line-height:2;}
.footer-info a{color:rgba(255,255,255,.35);text-decoration:none;}

/* MODAL */
.modal-ov{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:20px;}
.modal-ov.open{display:flex;}
.modal-box{background:#fff;border-radius:18px;width:100%;max-width:380px;padding:32px 28px;position:relative;animation:mIn .28s cubic-bezier(.34,1.56,.64,1);background-image:var(--bg-paper);background-size:160px;}
@keyframes mIn{from{transform:scale(.88);opacity:0;}to{transform:scale(1);opacity:1;}}
.modal-logo{text-align:center;margin-bottom:18px;}
.modal-logo svg{height:48px;width:auto;}
.modal-logo .ml-jp{font-family:'Noto Serif JP',serif;font-size:12px;color:var(--text-soft);letter-spacing:2px;margin-top:3px;}
.mf{display:flex;flex-direction:column;gap:5px;margin-bottom:12px;}
.mf label{font-size:12.5px;font-weight:700;color:var(--navy);}
.mf input{padding:11px 14px;border:2px solid var(--border);border-radius:9px;font-size:13px;outline:none;font-family:inherit;background:rgba(26,39,68,.04);transition:.2s;}
.mf input:focus{border-color:var(--navy-mid);}
.modal-links{display:flex;justify-content:space-between;font-size:11.5px;margin-bottom:18px;}
.modal-links a{color:var(--text-soft);text-decoration:none;}
.modal-confirm{text-align:center;margin-bottom:14px;}
.modal-confirm .ck-btn{font-size:26px;color:var(--gold);cursor:pointer;background:none;border:none;}
.modal-footer{display:flex;gap:10px;}
.mf-btn{flex:1;padding:11px;border-radius:9px;font-family:inherit;font-size:13.5px;font-weight:700;cursor:pointer;border:none;transition:.15s;}
.mf-btn.pri{background:var(--navy);color:#fff;}
.mf-btn.sec{background:transparent;border:2px solid var(--border);color:var(--navy);}
.mf-btn:hover{opacity:.8;}
.modal-x{position:absolute;top:12px;right:14px;font-size:18px;cursor:pointer;color:var(--text-soft);background:none;border:none;}

/* REVEAL */
.reveal{opacity:0;transform:translateY(24px);transition:opacity .55s ease,transform .55s ease;}
.reveal.in{opacity:1;transform:none;}

/* RESPONSIVE */
@media(max-width:720px){
  .hero-card{grid-template-columns:1fr;}
  .hero-card-right{min-height:220px;}
  .hero-illus{width:85%;right:-5px;}
  .about-grid{grid-template-columns:1fr;gap:32px;}
  .levels-grid{grid-template-columns:1fr;}
  .features-grid{grid-template-columns:1fr;}
  .pricing-wrap{grid-template-columns:1fr;}
  .section-typebook{flex-direction:column;text-align:center;}
  footer{flex-direction:column;text-align:center;}
  .footer-info{text-align:center;}
}
</style>
</head>
<body>

<div class="ticker"><div class="ticker-inner">
  <span class="hi">今日から冒険始めます！</span><span>不再死背五十音，用打字練出日語腦</span>
