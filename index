<script>
function openModal(){document.getElementById('loginModal').classList.add('open');}
function closeModal(){document.getElementById('loginModal').classList.remove('open');}

const obs=new IntersectionObserver(e=>e.forEach(n=>{if(n.isIntersecting)n.target.classList.add('in');}),{threshold:.1});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

const demos=[
  {kana:['か','つ','て','、','せ','か','い','は','や','み','に','つ','つ','ま','れ','て','い','た'],romaji:['ka','tsu','te',null,'se','ka','i','ha','ya','mi','ni','tsu','tsu','ma','re','te','i','ta'],zh:'過去，世界曾被黑暗包羅。'},
  {kana:['し','か','し','い','ま','、','わ','か','も','の','が','た','ち','あ','が','る'],romaji:['shi','ka','shi','i','ma',null,'wa','ka','mo','no','ga','ta','chi','a','ga','ru'],zh:'但現在，一名年輕人站了起來。'},
  {kana:['よ','う','し','ゃ','の','た','び'],romaji:['yo','u','sha',null,'no','ta','bi'],zh:'勇者の旅。'},
];
let di=0,ci=0;
function render(){
  const s=demos[di];
  document.getElementById('demo-jp').innerHTML=s.kana.map((k,i)=>`<span class="dc${i<ci?' done':''}${i===ci?' cur':''}">${k}</span>`).join('');
  document.getElementById('demo-zh').textContent=ci>=s.kana.length?s.zh:'';
  document.getElementById('demo-hint').textContent=ci>=s.kana.length?'✨ 完成！按下一題繼續':'按順序輸入每個假名的羅馬拼音';
}
document.getElementById('demo-input').addEventListener('input',e=>{
  const v=e.target.value.toLowerCase().trim();
  const s=demos[di];
  if(ci>=s.kana.length){e.target.value='';di=(di+1)%demos.length;ci=0;render();return;}
  if(s.romaji[ci]===null){ci++;render();}
  const t=s.romaji[ci];
  if(!t){ci++;render();return;}
  if(v===t){
    ci++;e.target.value='';e.target.className='demo-input right';
    setTimeout(()=>e.target.className='demo-input',200);render();
    if(ci>=s.kana.length){render();}
  }else if(v.length>0&&!t.startsWith(v)){
    e.target.className='demo-input wrong';
    setTimeout(()=>{e.target.className='demo-input';e.target.value='';render();},300);
  }
});
render();
</script>
